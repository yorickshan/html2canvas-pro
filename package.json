{
  "name": "html2canvas-pro",
  "description": "Screenshots with JavaScript. Next generation!",
  "type": "module",
  "main": "dist/html2canvas-pro.js",
  "module": "dist/html2canvas-pro.esm.js",
  "typings": "dist/types/index.d.ts",
  "browser": "dist/html2canvas-pro.esm.js",
  "sideEffects": false,
  "files": [
    "dist/",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/html2canvas-pro.esm.js",
      "require": "./dist/html2canvas-pro.js",
      "default": "./dist/html2canvas-pro.esm.js"
    }
  },
  "version": "2.2.0",
  "packageManager": "pnpm@10.9.0",
  "author": {
    "name": "yorickshan",
    "email": "yorickshan@gmail.com",
    "url": "https://github.com/yorickshan"
  },
  "license": "MIT",
  "keywords": [
    "html2canvas",
    "screenshot"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "homepage": "https://yorickshan.github.io/html2canvas-pro/",
  "repository": {
    "type": "git",
    "url": "https://github.com/yorickshan/html2canvas-pro"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.6",
    "@types/karma": "^6.3.0",
    "@types/mocha": "^10.0.7",
    "@types/node": "^25.0.3",
    "@types/platform": "^1.3.4",
    "@types/pngjs": "^6.0.5",
    "@types/serve-index": "^1.9.4",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitest/coverage-v8": "^3.2.6",
    "appium-ios-simulator": "^8.0.9",
    "base64-arraybuffer": "1.0.2",
    "body-parser": "^2.2.1",
    "chai": "6.2.2",
    "change-case": "^5.4.4",
    "conventional-changelog": "^7.2.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cors": "^2.8.5",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "express": "^5.2.1",
    "filenamify-url": "4.0.0",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "karma": "^6.3.2",
    "karma-chrome-launcher": "^3.1.0",
    "karma-edge-launcher": "^0.4.2",
    "karma-firefox-launcher": "^2.1.0",
    "karma-ie-launcher": "^1.0.0",
    "karma-junit-reporter": "^2.0.1",
    "karma-mocha": "^2.0.1",
    "karma-safarinative-launcher": "^1.1.0",
    "lint-staged": "^16.2.7",
    "mocha": "^11.7.5",
    "node-simctl": "^8.1.2",
    "pixelmatch": "^7.2.0",
    "platform": "^1.3.6",
    "pngjs": "^7.0.0",
    "prettier": "^3.3.3",
    "puppeteer": "^24.34.0",
    "replace-in-file": "^8.4.0",
    "rimraf": "^6.0.1",
    "rolldown": "^1.1.2",
    "serve-index": "^1.9.1",
    "slash": "5.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.19",
    "typescript": "^5.5.4",
    "uglify-js": "^3.13.10",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.6",
    "yargs": "^18.0.0"
  },
  "scripts": {
    "prebuild": "rimraf dist/ && rimraf build/ && mkdir -p dist && mkdir -p build",
    "build": "tsc --module commonjs -p tsconfig.build.json && rolldown -c rolldown.config.ts && pnpm build:create-reftest-list && rolldown -c tests/rolldown.testrunner.config.ts && pnpm build:minify",
    "build:testrunner": "rolldown -c tests/rolldown.testrunner.config.ts",
    "build:minify": "uglifyjs --compress --comments /^!/ -o dist/html2canvas-pro.min.js --mangle -- dist/html2canvas-pro.js",
    "build:reftest-result-list": "tsx scripts/create-reftest-result-list.ts",
    "build:create-reftest-list": "tsx scripts/create-reftest-list.ts tests/reftests/ignore.txt build/reftests.js",
    "release": "sh scripts/version-upgrade.sh",
    "format": "prettier --write \"{src,tests,scripts}/**/*.ts\"",
    "lint": "eslint src/**/*.ts --max-warnings 0",
    "test": "pnpm lint && pnpm unittest && pnpm karma",
    "unittest": "vitest run",
    "unittest:coverage": "vitest run --coverage",
    "bench:css-parse": "tsx scripts/benchmarks/css-parse.bench.ts",
    "reftests-diff": "mkdir -p tmp/snapshots && vitest run --config vitest.reftest.config.ts",
    "prekarma": "node scripts/ensure-karma-prereqs.mjs",
    "karma": "tsx tests/karma",
    "watch": "rolldown -w",
    "watch:unittest": "vitest",
    "start": "tsx tests/server --port=8080 --cors=8081",
    "commitlint": "commitlint --config .commitlintrc.json -e -V",
    "prepare": "if [ \"$SKIP_PREPARE\" != \"true\" ]; then husky install; fi",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:api": "typedoc",
    "docs:api:watch": "typedoc --watch"
  },
  "dependencies": {
    "css-line-break": "^2.1.0",
    "text-segmentation": "^1.0.3"
  },
  "lint-staged": {
    "{src,tests}/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
